<div align="center">

<!-- Animated Header -->
<img src="https://capsule-render.vercel.app/api?type=waving&color=0:{{ config.theme.bg }},50:{{ config.theme.bg_secondary }},100:{{ config.theme.border }}&height=230&section=header&text={{ (profile.name or username) | urlencode }}&fontSize=48&fontColor={{ config.theme.accent }}&animation=fadeIn&fontAlignY=32&desc={{ config.tagline | urlencode }}&descSize=17&descColor={{ config.theme.text }}&descAlignY=52" width="100%" alt="Header" />

<!-- Typing Animation -->
<a href="https://github.com/{{ username }}">
  <img src="https://readme-typing-svg.demolab.com?font=Fira+Code&weight=500&size=22&duration=3000&pause=1000&color={{ config.theme.accent | upper }}&center=true&vCenter=true&multiline=true&repeat=true&width=620&height=55&lines={{ config.current_focus | urlencode }};{{ config.status.mood | urlencode }}" alt="Typing SVG" />
</a>

<br>

<!-- Profile Badges Row -->
<a href="https://github.com/{{ username }}?tab=followers">
  <img src="https://img.shields.io/github/followers/{{ username }}?label=Followers&style=for-the-badge&logo=github&logoColor=white&color={{ config.theme.bg }}&labelColor={{ config.theme.bg_secondary }}" alt="Followers">
</a>
<img src="https://img.shields.io/github/stars/{{ username }}?label=Stars&style=for-the-badge&logo=github&logoColor=white&color={{ config.theme.bg }}&labelColor={{ config.theme.bg_secondary }}&affiliations=OWNER" alt="Stars">
<img src="https://komarev.com/ghpvc/?username={{ username }}&style=for-the-badge&color={{ config.theme.bg }}&label=VISITORS&labelColor={{ config.theme.bg_secondary }}" alt="Profile Views">
{% if config.social.medium %}
<a href="https://medium.com/@{{ config.social.medium }}">
  <img src="https://img.shields.io/badge/Medium-Articles-{{ config.theme.bg }}?style=for-the-badge&logo=medium&logoColor=white&labelColor={{ config.theme.bg_secondary }}" alt="Medium">
</a>
{% endif %}
{% if config.social.linkedin %}
<a href="https://linkedin.com/in/{{ config.social.linkedin }}">
  <img src="https://img.shields.io/badge/LinkedIn-Connect-{{ config.theme.bg }}?style=for-the-badge&logo=linkedin&logoColor=white&labelColor={{ config.theme.bg_secondary }}" alt="LinkedIn">
</a>
{% endif %}
{% if config.social.twitter %}
<a href="https://twitter.com/{{ config.social.twitter }}">
  <img src="https://img.shields.io/badge/Twitter-Follow-{{ config.theme.bg }}?style=for-the-badge&logo=x&logoColor=white&labelColor={{ config.theme.bg_secondary }}" alt="Twitter">
</a>
{% endif %}

</div>

<br>

<!-- ═══════════════════════════════════════════════════════ -->

## <img src="https://raw.githubusercontent.com/Tarikul-Islam-Anik/Animated-Fluent-Emojis/master/Emojis/People%20with%20professions/Man%20Technologist%20Light%20Skin%20Tone.png" width="30"> &nbsp;Who Am I

<table>
<tr>
<td width="50%" valign="top">

```yaml
name: {{ profile.name or username }}
role: {{ profile.bio or "Software Architect" }}
from: GitHub since {{ profile.created_at[:4] if profile.created_at else "N/A" }}
repos: {{ profile.public_repos }}
{% if profile.hireable %}open_to_work: true
{% endif %}```

> *"{{ config.thoughts | random }}"*

</td>
<td width="50%" valign="top">

{% if config.status.working_on %}
**`Working on`** &nbsp; {{ config.status.working_on }}
{% endif %}
{% if config.status.learning %}
**`Learning`** &nbsp;&nbsp;&nbsp;&nbsp; {{ config.status.learning }}
{% endif %}
{% if config.status.ask_me_about %}
**`Ask me`** &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; {{ config.status.ask_me_about }}
{% endif %}
{% if config.status.collaborating_on %}
**`Collab on`** &nbsp;&nbsp;&nbsp; {{ config.status.collaborating_on }}
{% endif %}

</td>
</tr>
</table>

{% if config.fun_facts %}
<details>
<summary>&nbsp;<b>Fun facts about me</b>&nbsp; <sup>(click to expand)</sup></summary>
<br>

{% for fact in config.fun_facts %}
&nbsp;&nbsp; {{ fact }} <br>
{% endfor %}

</details>
{% endif %}

<!-- ═══════════════════════════════════════════════════════ -->

